// ─── CLIENTS ─────────────────────────────────────────────────────────────────

app.get("/api/clients", (_, res) => {
  const rows = db.prepare("SELECT * FROM clients ORDER BY id DESC").all();
  res.json(rows.map(dbClientToClient));
});

app.post("/api/clients", (req, res) => {
  const b = req.body;
  const stmt = db.prepare(`
    INSERT INTO clients (name,phone,email,gender,birthday,comment,debt,repaid,grp,sum,last_buy,created)
    VALUES (@name,@phone,@email,@gender,@birthday,@comment,@debt,@repaid,@grp,@sum,@last_buy,@created)
  `);
  const info = stmt.run({
    name:     b.name     ?? "",
    phone:    b.phone    ?? "",
    email:    b.email    ?? "",
    gender:   b.gender   ?? "",
    birthday: b.birthday ?? "",
    comment:  b.comment  ?? "",
    debt:     b.debt     ?? 0,
    repaid:   b.repaid   ?? 0,
    grp:      b.group    ?? "",
    sum:      b.sum      ?? 0,
    last_buy: b.lastBuy  ?? null,
    created:  b.created  ?? new Date().toLocaleDateString("ru-RU"),
  });
  const row = db.prepare("SELECT * FROM clients WHERE id = ?").get(info.lastInsertRowid);
  res.json(dbClientToClient(row));
});

app.patch("/api/clients/:id", (req, res) => {
  const b = req.body;
  db.prepare(`
    UPDATE clients SET
      name=@name, phone=@phone, email=@email, gender=@gender,
      birthday=@birthday, comment=@comment, debt=@debt,
      repaid=@repaid, grp=@grp, sum=@sum, last_buy=@last_buy
    WHERE id=@id
  `).run({
    id:       req.params.id,
    name:     b.name     ?? "",
    phone:    b.phone    ?? "",
    email:    b.email    ?? "",
    gender:   b.gender   ?? "",
    birthday: b.birthday ?? "",
    comment:  b.comment  ?? "",
    debt:     b.debt     ?? 0,
    repaid:   b.repaid   ?? 0,
    grp:      b.group    ?? "",
    sum:      b.sum      ?? 0,
    last_buy: b.lastBuy  ?? null,
  });
  const row = db.prepare("SELECT * FROM clients WHERE id=?").get(req.params.id);
  res.json(dbClientToClient(row));
});

app.delete("/api/clients/:id", (req, res) => {
  db.prepare("DELETE FROM clients WHERE id=?").run(req.params.id);
  res.json({ ok: true });
});

function dbClientToClient(r: any) {
  return {
    id:        r.id,
    name:      r.name,
    phone:     r.phone,
    email:     r.email,
    gender:    r.gender,
    birthday:  r.birthday,
    comment:   r.comment,
    debt:      r.debt,
    repaid:    r.repaid,
    group:     r.grp,
    sum:       r.sum,
    lastBuy:   r.last_buy,
    createdAt: 0,
    created:   r.created,
  };
}

