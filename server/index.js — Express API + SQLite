// ─── SALES ───────────────────────────────────────────────────────────────────

app.get("/api/sales", (_, res) => {
  const rows = db.prepare("SELECT * FROM sales ORDER BY id DESC").all();
  res.json(rows.map(dbSaleToSale));
});

app.post("/api/sales", (req, res) => {
  const b = req.body;
  const stmt = db.prepare(`
    INSERT INTO sales
      (rcp_id,date,time,type,product_id,p_name,art,qty,price,total,cost,profit,pay,pt,discount,client_id,note)
    VALUES
      (@rcp_id,@date,@time,@type,@product_id,@p_name,@art,@qty,@price,@total,@cost,@profit,@pay,@pt,@discount,@client_id,@note)
  `);
  const info = stmt.run({
    rcp_id:     b.rcpId     ?? "",
    date:       b.date      ?? "",
    time:       b.time      ?? "",
    type:       b.type      ?? "продажа",
    product_id: b.productId ?? 0,
    p_name:     b.pName     ?? "",
    art:        b.art       ?? "",
    qty:        b.qty       ?? 1,
    price:      b.price     ?? 0,
    total:      b.total     ?? 0,
    cost:       b.cost      ?? 0,
    profit:     b.profit    ?? 0,
    pay:        b.pay       ?? "cash",
    pt:         b.pt        ?? "retail",
    discount:   b.discount  ?? 0,
    client_id:  b.clientId  ?? "",
    note:       b.note      ?? "",
  });

  // Списываем остаток товара
  if (b.productId) {
    db.prepare("UPDATE products SET qty = MAX(0, qty - ?) WHERE id = ?")
      .run(b.qty ?? 1, b.productId);
  }

  // Обновляем сумму покупок клиента
  if (b.clientId) {
    db.prepare("UPDATE clients SET sum = sum + ?, last_buy = ? WHERE id = ?")
      .run(b.total ?? 0, b.date, b.clientId);
  }

  const row = db.prepare("SELECT * FROM sales WHERE id=?").get(info.lastInsertRowid);
  res.json(dbSaleToSale(row));
});

function dbSaleToSale(r: any) {
  return {
    id:        r.id,
    rcpId:     r.rcp_id,
    date:      r.date,
    time:      r.time,
    type:      r.type,
    productId: r.product_id,
    pName:     r.p_name,
    art:       r.art,
    qty:       r.qty,
    price:     r.price,
    total:     r.total,
    cost:      r.cost,
    profit:    r.profit,
    pay:       r.pay,
    pt:        r.pt,
    discount:  r.discount,
    clientId:  r.client_id,
    note:      r.note,
  };
}

